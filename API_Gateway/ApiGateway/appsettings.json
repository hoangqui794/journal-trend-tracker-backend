{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity-api/{**remainder}"
        },
        "RateLimiterPolicy": "fixed",
        "Transforms": [
          {
            "PathRemovePrefix": "/identity-api"
          }
        ]
      },
      "paper-route": {
        "ClusterId": "paper-cluster",
        "Match": {
          "Path": "/paper-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/paper-api"
          }
        ]
      },
      "trend-route": {
        "ClusterId": "trend-cluster",
        "Match": {
          "Path": "/trend-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/trend-api"
          }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/user-api"
          }
        ]
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/admin-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/admin-api"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5251"
          }
        }
      },
      "paper-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "trend-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5005"
          }
        }
      }
    }
  },
  "Jwt": {
    "Secret": "default_secret_key_that_is_long_enough_32_bytes",
    "Issuer": "IdentityService",
    "Audience": "ApiGateway"
  }
}
