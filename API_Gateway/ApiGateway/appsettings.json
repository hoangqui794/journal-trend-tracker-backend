{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity-api/{**remainder}"
        },
        "RateLimiterPolicy": "fixed",
        "Transforms": [
          {
            "PathRemovePrefix": "/identity-api"
          }
        ]
      },
      "paper-route": {
        "ClusterId": "paper-cluster",
        "Match": {
          "Path": "/paper-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/paper-api"
          }
        ]
      },
      "trend-route": {
        "ClusterId": "trend-cluster",
        "Match": {
          "Path": "/trend-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/trend-api"
          }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/user-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/user-api"
          }
        ]
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/admin-api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/admin-api"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://identity-service-6r7e.onrender.com"
          }
        }
      },
      "paper-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://paper-service-ynmc.onrender.com"
          }
        }
      },
      "trend-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://trend-service-ab5q.onrender.com"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://user-service-rje9.onrender.com"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "d1": {
            "Address": "https://admin-service-y388.onrender.com"
          }
        }
      }
    }
  }
}
